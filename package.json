{
  "name": "deploy-gates",
  "version": "0.0.0",
  "private": true,
  "description": "Release gating showcase: Pact contract verification and k6 performance thresholds as one unified deploy gate",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "services/provider",
    "services/consumer"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:pact": "vitest run --config pact/vitest.config.ts",
    "pact:verify": "tsx pact/provider/verify.ts",
    "pact:publish": "pact-broker publish pact/pacts --broker-base-url $PACT_BROKER_BASE_URL --broker-username $PACT_BROKER_USERNAME --broker-password $PACT_BROKER_PASSWORD --consumer-app-version $GIT_COMMIT_SHA --branch $GIT_BRANCH",
    "pact:can-i-deploy": "pact-broker can-i-deploy --broker-base-url $PACT_BROKER_BASE_URL --broker-username $PACT_BROKER_USERNAME --broker-password $PACT_BROKER_PASSWORD --pacticipant consumer --version $GIT_COMMIT_SHA --pacticipant provider --version $GIT_COMMIT_SHA",
    "perf": "k6 run k6/load.js",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.31.0",
    "@pact-foundation/pact": "^17.0.1",
    "@pact-foundation/pact-cli": "^18.1.1",
    "@types/node": "^22.15.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0",
    "vitest": "^3.2.4"
  }
}
